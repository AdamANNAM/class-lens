{
  "name": "class-lens",
  "displayName": "Class Lens — Inline className & class Preview",
  "description": "Identify closing tags by their className and class values. Inline preview for JSX, TSX, HTML, Vue, Svelte, Astro, React, and Tailwind.",
  "version": "0.1.0",
  "publisher": "Homuzu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdamANNAM/class-lens"
  },
  "homepage": "https://github.com/AdamANNAM/class-lens",
  "bugs": {
    "url": "https://github.com/AdamANNAM/class-lens/issues"
  },
  "qna": "marketplace",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.67.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "className",
    "closing tag",
    "CSS",
    "class",
    "annotation",
    "preview",
    "inline",
    "JSX",
    "TSX",
    "HTML",
    "Tailwind",
    "React",
    "Vue",
    "Svelte",
    "Astro",
    "inlay hint"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Class Lens",
      "properties": {
        "classLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable className preview annotations"
        },
        "classLens.renderMode": {
          "type": "string",
          "default": "decoration",
          "enum": [
            "decoration",
            "inlayHint"
          ],
          "enumDescriptions": [
            "Text decorations appended after closing tags",
            "Native VS Code inlay hints"
          ],
          "description": "Rendering mode for className previews"
        },
        "classLens.maxLength": {
          "type": "number",
          "default": 40,
          "description": "Maximum characters to display (0 = no truncation)"
        },
        "classLens.truncateType": {
          "type": "string",
          "default": "word",
          "enum": [
            "character",
            "word"
          ],
          "enumDescriptions": [
            "Truncate at exact character count",
            "Truncate at word boundary (split on spaces)"
          ],
          "description": "Truncate at exact character count or at word boundary"
        },
        "classLens.truncatePosition": {
          "type": "string",
          "default": "end",
          "enum": [
            "end",
            "start"
          ],
          "enumDescriptions": [
            "Keep the start of the value, truncate the end",
            "Keep the end of the value, truncate the start"
          ],
          "description": "Truncate from the end (keep start) or from the start (keep end)"
        },
        "classLens.opacity": {
          "type": "string",
          "default": "0.9",
          "description": "CSS opacity for annotations"
        },
        "classLens.prefix": {
          "type": "string",
          "default": "/*",
          "description": "Prefix before the class value (e.g. '/*' to pair with a '*/' suffix for block-comment style). A space between prefix and value is inserted automatically."
        },
        "classLens.suffix": {
          "type": "string",
          "default": "*/",
          "description": "Suffix after the class value. A space between value and suffix is inserted automatically."
        },
        "classLens.ellipsis": {
          "type": "string",
          "default": "...",
          "description": "Marker shown when a class value is truncated (appended for truncatePosition='end', prepended for 'start'; set to '' to disable)."
        },
        "classLens.showSameLine": {
          "type": "boolean",
          "default": false,
          "description": "Show the className preview comment when a tag's opening and closing are on the same line."
        },
        "classLens.hideSelfClosing": {
          "type": "boolean",
          "default": false,
          "description": "Hide className previews on self-closing tags (e.g. <input />, <img />). When false (default), self-closing tags are annotated like any other tag, subject to showSameLine. When true, self-closing tags get no annotation."
        },
        "classLens.excludedLanguages": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Language IDs where the extension should NOT show annotations"
        },
        "classLens.transformPatterns": {
          "type": "array",
          "default": [
            {
              "pattern": "^classNames\\((.*)\\)$",
              "replacement": "$1",
              "flags": "s"
            },
            {
              "pattern": "^clsx\\((.*)\\)$",
              "replacement": "$1",
              "flags": "s"
            },
            {
              "pattern": "^cx\\((.*)\\)$",
              "replacement": "$1",
              "flags": "s"
            },
            {
              "pattern": "^cn\\((.*)\\)$",
              "replacement": "$1",
              "flags": "s"
            },
            {
              "pattern": "styles\\.",
              "replacement": "",
              "flags": "g"
            },
            {
              "pattern": "\\$style\\.",
              "replacement": "",
              "flags": "g"
            },
            {
              "pattern": "\\bclassName\\b\\s*,\\s*|,\\s*\\bclassName\\b|\\bclassName\\b",
              "replacement": "",
              "flags": "g"
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex pattern string"
              },
              "replacement": {
                "type": "string",
                "default": "",
                "description": "Replacement string (supports $1, $2, etc.)"
              },
              "flags": {
                "type": "string",
                "default": "g",
                "description": "Regex flags (default: \"g\")"
              }
            },
            "required": [
              "pattern"
            ]
          },
          "markdownDescription": "Array of regex transform patterns applied to hint values before display. Each entry has `pattern` (regex string), `replacement` (default `\"\"`), and `flags` (default `\"g\"`). Transforms run in order.\n\nExample to strip `styles.` prefix and unwrap `classNames()`:\n```json\n[\n  { \"pattern\": \"styles\\\\.\", \"replacement\": \"\", \"flags\": \"g\" },\n  { \"pattern\": \"^classNames\\\\((.*)\\\\)$\", \"replacement\": \"$1\", \"flags\": \"s\" }\n]\n```"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run type-check && tsc -p src/test/tsconfig.json && node esbuild.js",
    "type-check": "tsc --noEmit",
    "watch": "node esbuild.js --watch",
    "package": "npm run type-check && node esbuild.js --production",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "vsix": "npm run package && vsce package --no-dependencies",
    "vsix:install": "npm run vsix && code --install-extension class-lens-0.1.0.vsix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.67.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
